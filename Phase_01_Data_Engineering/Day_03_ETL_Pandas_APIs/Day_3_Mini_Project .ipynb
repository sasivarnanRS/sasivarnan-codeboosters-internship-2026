      "source": [
        "df = pd.read_csv(\"employee_salary_messy_data.csv\")\n",
        "\n",
        "print(\"ORIGINAL DATA:\")\n",
        "print(df)\n",
        "\n",
        "print(\"\\nMISSING VALUES:\")\n",
        "print(df.isnull().sum())\n",
        "\n",
        "\n",
        "print(\"\\nDUPLICATE ROWS:\", df.duplicated().sum())\n",
        "\n",
        "\n",
        "df = df.drop_duplicates()\n",
        "\n",
        "\n",
        "df = df.dropna(subset=[\"Monthly_Salary\"])\n",
        "\n",
        "\n",
        "df[\"Yearly_Salary\"] = df[\"Monthly_Salary\"] * 12\n",
        "\n",
        "\n",
        "df = df.reset_index(drop=True)\n",
        "\n",
        "print(\"\\nCLEANED DATA:\")\n",
        "print(df)\n",
        "\n",
        "df.to_csv(\"cleaned_employee_salary.csv\", index=False)\n",
        "\n",
        "print(\"\\nCLEANED CSV FILE SAVED SUCCESSFULLY\")\n",
        "print(\"\\nFinal Shape:\", df.shape)"
